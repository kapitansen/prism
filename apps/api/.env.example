# Copy to .env and adjust. .env is git-ignored; .env.example is committed.

# Postgres connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://prism:prism@localhost:5432/prism?schema=public"

# HTTP port the Nest API listens on.
PORT=3000

# Secret for signing JWT access tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-random-secret
JWT_EXPIRES_IN=7d
