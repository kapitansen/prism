# Copy to .env and adjust. .env is git-ignored; .env.example is committed.

# Postgres connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://prism:prism@localhost:5432/prism?schema=public"

# HTTP port the Nest API listens on.
PORT=3000

# Secret for signing JWT access tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-random-secret
JWT_EXPIRES_IN=7d

# AES-256-GCM key for encrypting _enc fields. 32 bytes. Generate with: openssl rand -hex 32
# NEVER commit the real value; keep it out of the DB and backups.
ENCRYPTION_KEY=change-me-generate-a-32-byte-hex-key

# LLM runner: `claude-code` (Claude Code CLI, Max subscription — default), `api`
# (Claude API, planned), or `fake` (deterministic, used by tests).
# LLM_RUNNER=claude-code
# Per-call timeout for the Claude Code CLI in ms. Analysis with MCP tool-use can
# take a few minutes; raise this if parses time out. Default 300000 (5 min).
# CLAUDE_TIMEOUT_MS=300000
# Set to 0 to disable the MCP pull layer during analysis (no DB lookups mid-run).
# PRISM_ANALYSIS_MCP=1
